# Copy this file to Frontend/.env and fill in real values.
# Vite only exposes variables prefixed with VITE_ to the browser.

# Base URL of the Curbside API.
VITE_API_URL=http://localhost:4000/api

# Cloudinary — client-direct, unsigned uploads.
# These are PUBLIC values (safe to ship in the browser bundle), not secrets.
# Create an UNSIGNED upload preset in Cloudinary > Settings > Upload.
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset
