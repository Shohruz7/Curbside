# Repo-root environment file used by docker-compose variable substitution.
# Copy to .env (which is gitignored) and fill in real values before running
# `docker compose up`.

# Secret used to sign JWTs. Compose refuses to start the server without it.
JWT_SECRET=change_me_to_a_long_random_string

# Optional override. Defaults to the internal mongo service in docker-compose.yml.
# MONGO_URI=mongodb://mongo:27017/curbside

# --- Frontend build-time vars (baked into the client bundle by Vite) ---
# These are read by docker-compose at BUILD time and compiled into the static
# JS. Changing them requires a rebuild: `docker compose build client` (a plain
# restart will NOT pick up new values). All are safe to ship in the browser.

# Base URL the browser uses to reach the API. For a real deploy set this to the
# public API URL (e.g. https://api.yourdomain.com/api). Defaults to localhost.
# VITE_API_URL=http://localhost:4000/api

# Cloudinary unsigned upload (photo uploads). Create an UNSIGNED upload preset
# in Cloudinary > Settings > Upload. Leave blank to fall back to URL-paste.
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
# VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset
